            <!-- Contact -->
            <section id="contact" class="bg-secondary text-base-content px-8 py-16 text-center scroll-mt-24">
                <h2 class="text-3xl font-bold mb-4">Let's Connect</h2>
                <p class="mb-8">Interested in working together, or just want to say hi? Reach out below.</p>
                <a href="mailto:judytramnguyen@gmail.com" class="btn btn-primary">Say Hello</a>
            </section>

        </div>
    </div>
</main>

